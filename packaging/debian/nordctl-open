#!/usr/bin/env bash
# Launch nordctl dashboard from the desktop / app menu.
set -euo pipefail

NORDCTL=/usr/bin/nordctl
export PATH="/usr/bin:/bin:/usr/bin:${PATH:-}"

if [[ ! -x "$NORDCTL" ]]; then
  echo "nordctl is not installed." >&2
  exit 1
fi

if [[ ! -f "${HOME}/.config/nordctl/config.yaml" ]]; then
  "$NORDCTL" init --skip-onboard
fi

# --json must follow "service", not "bootstrap" (argparse parent on service subparser).
result=$("$NORDCTL" service --json bootstrap 2>/dev/null || echo '{"ok":false,"error":"bootstrap failed"}')
eval "$(python3 -c "
import json, shlex, sys
d = json.loads(sys.argv[1])
ok = '1' if d.get('ok') and d.get('url') else '0'
print('ok=%s' % ok)
print('url=%s' % shlex.quote(d.get('url') or ''))
print('err=%s' % shlex.quote(d.get('error') or 'Could not start the nordctl dashboard.'))
" "$result")"

if [[ "$ok" != "1" || -z "$url" ]]; then
  if command -v zenity >/dev/null 2>&1; then
    zenity --error --title="nordctl" --text="$err" 2>/dev/null || true
  else
    echo "$err" >&2
  fi
  exit 1
fi

if command -v xdg-open >/dev/null 2>&1; then
  xdg-open "$url" >/dev/null 2>&1 &
elif command -v gio >/dev/null 2>&1; then
  gio open "$url" >/dev/null 2>&1 &
else
  echo "Dashboard ready at $url"
fi
